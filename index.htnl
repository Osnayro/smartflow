
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>SmartFlow Pro v7.8 - Colector y Distribuidor Automático</title>
<style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{background:#000;color:#fff;height:100vh;display:flex;flex-direction:column;overflow:hidden}
    .toolbar{background:#1a1a2e;padding:8px;display:flex;flex-wrap:wrap;gap:6px;justify-content:center;border-bottom:1px solid #2a2a4a}
    button{background:#2c3e66;border:none;color:white;padding:8px 12px;border-radius:6px;font-weight:bold;cursor:pointer;font-size:12px}
    button:hover{background:#3b5a8c}
    .btn-primary{background:#238636}
    .btn-warning{background:#d29922;color:#1f1f1f}
    .btn-danger{background:#da3633}
    .canvas-container{flex:1;position:relative;background:#000}
    canvas{display:block;width:100%;height:100%;cursor:grab}
    canvas:active{cursor:grabbing}
    .command-panel{position:fixed;left:10px;bottom:10px;width:90%;max-width:500px;background:#1e1e2e;border-radius:12px;border:1px solid #7c3aed;z-index:1000;display:none}
    .command-header{display:flex;justify-content:space-between;padding:12px;border-bottom:1px solid #3a3a4a}
    .command-buttons{display:flex;gap:8px;padding:12px}
    textarea{width:calc(100% - 24px);margin:12px;background:#0f0f17;color:#eee;border:none;border-radius:8px;padding:12px;font-family:monospace;font-size:14px;resize:vertical}
    .notification{position:fixed;top:20px;left:50%;transform:translateX(-50%);background:#238636;padding:10px 20px;border-radius:8px;z-index:2000;display:none;text-align:center}
    .status-bar{background:#111;padding:6px;font-size:12px;text-align:center;border-top:1px solid #2a2a4a}
    .modal-reporte{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:#1e1e2e;border:2px solid #7c3aed;border-radius:12px;padding:20px;max-width:90%;max-height:80vh;overflow:auto;z-index:3000;font-family:monospace;white-space:pre-wrap}
    .modal-close{float:right;background:none;border:none;color:white;font-size:20px;cursor:pointer}
    @media (max-width:768px){button{padding:8px;font-size:11px}}
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
</head>
<body>
<div class="toolbar">
    <button id="btnNew" class="btn-primary">Nuevo</button>
    <button id="btnOpen">Abrir</button>
    <button id="btnSave">Guardar</button>
    <button id="btnReset">Centrar</button>
    <button id="btnCommand" class="btn-primary">Comandos</button>
    <button id="btnMTO">MTO</button>
    <button id="btnPDF">PDF</button>
    <button id="btnUndo" class="btn-warning">Deshacer</button>
    <button id="btnRedo" class="btn-warning">Rehacer</button>
    <button id="btnVoice" style="background:#7c3aed">Voz ON</button>
    <button id="btnApplyNorm">Normas</button>
</div>
<div class="canvas-container"><canvas id="isoCanvas"></canvas></div>
<div id="commandPanel" class="command-panel">
    <div class="command-header"><strong>Comando de voz o texto</strong><button id="closeCommand" style="background:none;border:none;color:white;font-size:20px;">Cerrar</button></div>
    <textarea id="commandText" rows="4" placeholder="Ejemplos:
crea 6 tanques en paralelo de 2380 mm diametro y 2900 mm altura
crea 2 bombas
crea distribuidor de 4 pulgadas desde TK-01 hasta TK-06 con desvio derecho 500 mm
conecta TK-01 con B-01 con tubo de 4 pulgadas
aplicar normas
auditar planta
exportar mto
resumen
eliminar TK-01"></textarea>
    <div class="command-buttons"><button id="runCommands" class="btn-primary">Ejecutar</button><button id="clearCommand">Limpiar</button></div>
</div>
<div id="notification" class="notification"></div>
<div class="status-bar" id="statusMsg">SmartFlow Pro v7.8 - Listo</div>

<script>

// ==================== CONFIGURACIÓN GLOBAL ====================
let db = { equipos: [], lines: [] };
let cam = { scale: 0.5, panX: 0, panY: 0 };
let dragging = false, lastPos = { x: 0, y: 0 };
let selectedElement = null;
let voiceEnabled = true;
let history = { past: [], future: [], maxSize: 30 };
let nextPointId = 1;

const canvas = document.getElementById('isoCanvas');
const ctx = canvas.getContext('2d');

// ==================== FUNCIONES AUXILIARES ====================
function notify(msg, isErr = false) {
    const n = document.getElementById('notification');
    n.textContent = msg;
    n.style.backgroundColor = isErr ? '#da3633' : '#238636';
    n.style.display = 'block';
    document.getElementById('statusMsg').innerHTML = msg;
    if (voiceEnabled && window.speechSynthesis) {
        window.speechSynthesis.cancel();
        const u = new SpeechSynthesisUtterance(msg);
        u.lang = 'es-ES';
        setTimeout(() => window.speechSynthesis.speak(u), 50);
    }
    setTimeout(() => n.style.display = 'none', 4000);
}

function saveState() {
    const state = JSON.parse(JSON.stringify({ equipos: db.equipos, lines: db.lines }));
    history.past.push(state);
    if (history.past.length > history.maxSize) history.past.shift();
    history.future = [];
}
function undo() {
    if (history.past.length === 0) return;
    const current = JSON.parse(JSON.stringify({ equipos: db.equipos, lines: db.lines }));
    history.future.push(current);
    const prev = history.past.pop();
    db.equipos = prev.equipos;
    db.lines = prev.lines;
    selectedElement = null;
    render();
    autoCenter();
    notify("Deshecho");
}
function redo() {
    if (history.future.length === 0) return;
    const current = JSON.parse(JSON.stringify({ equipos: db.equipos, lines: db.lines }));
    history.past.push(current);
    const next = history.future.pop();
    db.equipos = next.equipos;
    db.lines = next.lines;
    selectedElement = null;
    render();
    autoCenter();
    notify("Rehecho");
}

// ==================== PROYECCIÓN ISOMÉTRICA ====================
function project(p) {
    const cos30 = Math.cos(30 * Math.PI / 180);
    const sin30 = Math.sin(30 * Math.PI / 180);
    const x = (p.x - p.z) * cos30;
    const y = (p.x + p.z) * sin30 - p.y;
    return { x: x * cam.scale + cam.panX, y: y * cam.scale + cam.panY };
}

function drawGrid() {
    const step = 1000;
    const minX = -8000, maxX = 20000, minZ = -8000, maxZ = 15000;
    ctx.beginPath();
    ctx.strokeStyle = '#2a4a6a';
    ctx.lineWidth = 1;
    for (let x = minX; x <= maxX; x += step) {
        const p1 = project({ x, y: 0, z: minZ });
        const p2 = project({ x, y: 0, z: maxZ });
        ctx.moveTo(p1.x, p1.y);
        ctx.lineTo(p2.x, p2.y);
        ctx.stroke();
    }
    for (let z = minZ; z <= maxZ; z += step) {
        const p1 = project({ x: minX, y: 0, z });
        const p2 = project({ x: maxX, y: 0, z });
        ctx.moveTo(p1.x, p1.y);
        ctx.lineTo(p2.x, p2.y);
        ctx.stroke();
    }
}

function drawOrigin() {
    const o = project({ x: 0, y: 0, z: 0 });
    ctx.beginPath();
    ctx.moveTo(o.x - 20, o.y);
    ctx.lineTo(o.x + 20, o.y);
    ctx.moveTo(o.x, o.y - 20);
    ctx.lineTo(o.x, o.y + 20);
    ctx.strokeStyle = '#ff8888';
    ctx.lineWidth = 2;
    ctx.stroke();
    ctx.fillStyle = '#ff8888';
    ctx.font = '14px monospace';
    ctx.fillText('ORIGEN (0,0,0)', o.x + 15, o.y - 8);
}

// ==================== DIBUJO DE ELEMENTOS ====================
function drawTank(eq) {
    const p = project(eq);
    const w = (eq.diametro / 2) * cam.scale;
    const h = eq.altura * cam.scale;
    const topY = p.y - h/2;
    const bottomY = p.y + h/2;
    ctx.save();
    ctx.beginPath();
    ctx.ellipse(p.x, topY, w, w*0.5, 0, 0, 2*Math.PI);
    ctx.fillStyle = '#3b82f6';
    ctx.fill();
    ctx.fillRect(p.x - w, topY, w*2, h);
    ctx.beginPath();
    ctx.ellipse(p.x, bottomY, w, w*0.5, 0, 0, 2*Math.PI);
    ctx.fill();
    ctx.strokeStyle = 'white';
    ctx.lineWidth = 2;
    ctx.stroke();
    ctx.fillStyle = 'white';
    ctx.font = `bold ${Math.max(12, 14 * cam.scale)}px Arial`;
    ctx.fillText(eq.tag, p.x - 18, topY - 10);
    ctx.beginPath();
    ctx.arc(p.x, p.y, 8, 0, 2*Math.PI);
    ctx.fillStyle = '#ff8800';
    ctx.fill();
    ctx.strokeStyle = 'white';
    ctx.stroke();
    ctx.restore();
}

function drawPipe(line) {
    if (!line.points3D || line.points3D.length < 2) return;
    ctx.beginPath();
    const proj = line.points3D.map(p => project(p));
    ctx.moveTo(proj[0].x, proj[0].y);
    for (let i = 1; i < proj.length; i++) ctx.lineTo(proj[i].x, proj[i].y);
    ctx.strokeStyle = '#facc15';
    ctx.lineWidth = Math.max(4, (line.diameter || 4) * cam.scale);
    ctx.stroke();
    for (let p of proj) {
        ctx.beginPath();
        ctx.arc(p.x, p.y, 6, 0, 2*Math.PI);
        ctx.fillStyle = '#ef4444';
        ctx.fill();
        ctx.strokeStyle = 'white';
        ctx.stroke();
    }
}

function drawComponents(line) {
    if (!line.components) return;
    for (let comp of line.components) {
        const pos = getPositionOnLine(line, comp.param);
        if (!pos) continue;
        const p = project(pos);
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.beginPath();
        if (comp.type === 'VALVE') {
            ctx.moveTo(-6, -4); ctx.lineTo(0,0); ctx.lineTo(6,-4); ctx.lineTo(0,6); ctx.closePath();
            ctx.fillStyle = '#ffaa33'; ctx.fill(); ctx.stroke();
        } else if (comp.type === 'ELBOW') {
            ctx.arc(0,0,6,0,Math.PI/2); ctx.lineTo(6,0);
            ctx.fillStyle = '#88aaff'; ctx.fill(); ctx.stroke();
        } else if (comp.type === 'ADAPTADOR') {
            ctx.fillRect(-5,-3,10,6); ctx.fillStyle = '#cccc99'; ctx.fill(); ctx.stroke();
        } else if (comp.type === 'SOPORTE') {
            ctx.fillRect(-4,-6,8,12); ctx.fillStyle = '#aaaaaa'; ctx.fill(); ctx.stroke();
        }
        ctx.restore();
    }
}

function getPositionOnLine(line, t) {
    const pts = line.points3D;
    if (!pts || pts.length < 2) return null;
    if (t <= 0) return pts[0];
    if (t >= 1) return pts[pts.length-1];
    const idx = Math.floor(t * (pts.length-1));
    const seg = t * (pts.length-1) - idx;
    const p1 = pts[idx], p2 = pts[idx+1];
    return { x: p1.x + seg*(p2.x-p1.x), y: p1.y + seg*(p2.y-p1.y), z: p1.z + seg*(p2.z-p1.z) };
}

function render() {
    if (!ctx) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = '#000000';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.save();
    drawGrid();
    drawOrigin();
    for (let line of db.lines) drawPipe(line);
    for (let line of db.lines) drawComponents(line);
    for (let eq of db.equipos) drawTank(eq);
    if (selectedElement) {
        if (selectedElement.type === 'equipment') {
            const eq = selectedElement.obj;
            const p = project(eq);
            const w = (eq.diametro/2)*cam.scale;
            const h = eq.altura*cam.scale;
            ctx.beginPath();
            ctx.ellipse(p.x, p.y - h/2, w+3, (w+3)*0.5, 0, 0, 2*Math.PI);
            ctx.strokeStyle = '#facc15';
            ctx.lineWidth = 3;
            ctx.stroke();
        } else if (selectedElement.type === 'line') {
            const line = selectedElement.obj;
            if (line.points3D && line.points3D.length >= 2) {
                ctx.beginPath();
                const proj = line.points3D.map(p => project(p));
                ctx.moveTo(proj[0].x, proj[0].y);
                for (let i=1; i<proj.length; i++) ctx.lineTo(proj[i].x, proj[i].y);
                ctx.strokeStyle = '#facc15';
                ctx.lineWidth = Math.max(6, (line.diameter||4)*cam.scale);
                ctx.stroke();
            }
        }
    }
    ctx.restore();
}

// ==================== AUTO CENTRADO ====================
function autoCenter() {
    let points = [];
    db.equipos.forEach(eq => {
        const r = (eq.diametro || 1000) / 2;
        const h = (eq.altura || 2000);
        points.push({ x: eq.x, y: eq.y, z: eq.z });
        points.push({ x: eq.x + r, y: eq.y, z: eq.z });
        points.push({ x: eq.x - r, y: eq.y, z: eq.z });
        points.push({ x: eq.x, y: eq.y + h/2, z: eq.z });
        points.push({ x: eq.x, y: eq.y - h/2, z: eq.z });
        points.push({ x: eq.x, y: eq.y, z: eq.z + r });
        points.push({ x: eq.x, y: eq.y, z: eq.z - r });
    });
    db.lines.forEach(line => {
        if (line.points3D) points.push(...line.points3D);
    });
    if (points.length === 0) {
        points = [{ x: -2000, y: 0, z: -2000 }, { x: 2000, y: 2000, z: 2000 }];
    }
    const cos30 = Math.cos(30 * Math.PI / 180);
    const sin30 = Math.sin(30 * Math.PI / 180);
    let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
    points.forEach(p => {
        const rx = (p.x - p.z) * cos30;
        const ry = (p.x + p.z) * sin30 - p.y;
        if (rx < minX) minX = rx;
        if (rx > maxX) maxX = rx;
        if (ry < minY) minY = ry;
        if (ry > maxY) maxY = ry;
    });
    const marginX = (maxX - minX) * 0.15;
    const marginY = (maxY - minY) * 0.15;
    minX -= marginX;
    maxX += marginX;
    minY -= marginY;
    maxY += marginY;
    const worldW = maxX - minX;
    const worldH = maxY - minY;
    const padding = Math.min(Math.max(canvas.width * 0.1, 20), 80);
    const scaleX = (canvas.width - padding) / worldW;
    const scaleY = (canvas.height - padding) / worldH;
    let newScale = Math.min(scaleX, scaleY, 0.7);
    newScale = Math.max(newScale, 0.12);
    cam.scale = newScale;
    const worldCenterX = (minX + maxX) / 2;
    const worldCenterY = (minY + maxY) / 2;
    cam.panX = canvas.width / 2 - worldCenterX * cam.scale;
    cam.panY = canvas.height / 2 - worldCenterY * cam.scale;
    render();
}

// ==================== FUNCIONES DE INGENIERÍA ====================
function addEquipment(tipo, tagBase, diam = 2400, alt = 2900) {
    const tag = `${tagBase}-${(db.equipos.filter(e=>e.tipo===tipo).length+1).toString().padStart(2,'0')}`;
    let x = 0, z = 0;
    const last = db.equipos.filter(e=>e.tipo===tipo).pop();
    if (last) { x = last.x + 2500; z = last.z; }
    const y = (tipo==='tanque_v') ? alt/2 : 600;
    const newEq = { type:'equipment', tag, x, y, z, tipo, diametro: diam, altura: alt };
    db.equipos.push(newEq);
    notify(`Equipo ${tag} creado`);
    saveState();
    render();
    autoCenter();
}

function addPipe(tag, diam, material, points) {
    const newLine = { tag, diameter: diam, material, points3D: points, components: [] };
    db.lines.push(newLine);
    notify(`Tubería ${tag} creada`);
    saveState();
    render();
    autoCenter();
}

function calcularLongitud(line) {
    if (!line.points3D || line.points3D.length < 2) return 0;
    let len = 0;
    for (let i=0; i<line.points3D.length-1; i++) {
        len += Math.hypot(line.points3D[i+1].x - line.points3D[i].x,
                         line.points3D[i+1].y - line.points3D[i].y,
                         line.points3D[i+1].z - line.points3D[i].z);
    }
    return len;
}

function aplicarNormas() {
    let cambios = 0;
    for (let line of db.lines) {
        const diamMM = (line.diameter || 4) * 25.4;
        if (diamMM >= 110) {
            const long = calcularLongitud(line);
            const necesarios = Math.max(1, Math.floor(long / 1500));
            const actuales = line.components?.filter(c=>c.type==='SOPORTE').length || 0;
            for (let i=actuales; i<necesarios; i++) {
                if (!line.components) line.components = [];
                line.components.push({ type:'SOPORTE', tag:`SUP-${line.tag}-${i+1}`, param: (i+1)/(necesarios+1) });
                cambios++;
            }
        }
    }
    for (let bomba of db.equipos.filter(e=>e.tipo==='bomba')) {
        const lineasConectadas = db.lines.filter(l => l.points3D?.some(p => Math.hypot(p.x-bomba.x, p.y-bomba.y, p.z-bomba.z) < 500));
        for (let line of lineasConectadas) {
            if (!line.components) line.components = [];
            const tieneCheck = line.components.some(c=>c.type==='VALVE' && c.skey==='VCHK');
            if (!tieneCheck) {
                line.components.push({ type:'VALVE', tag:`CHK-${bomba.tag}`, param:0.85, skey:'VCHK', size:line.diameter });
                cambios++;
            }
        }
    }
    if (cambios) { notify(`Normas aplicadas: ${cambios} elementos añadidos`); render(); }
    else notify("La planta ya cumple las normas");
}

function auditarPlanta() {
    let alertas = [];
    for (let bomba of db.equipos.filter(e=>e.tipo==='bomba')) {
        const lineas = db.lines.filter(l => l.points3D?.some(p => Math.hypot(p.x-bomba.x, p.y-bomba.y, p.z-bomba.z) < 500));
        const tieneCheck = lineas.some(l => l.components?.some(c=>c.type==='VALVE' && c.skey==='VCHK'));
        if (!tieneCheck) alertas.push(`Bomba ${bomba.tag} sin válvula check`);
    }
    for (let line of db.lines) {
        const diamMM = (line.diameter||4)*25.4;
        if (diamMM >= 110) {
            const long = calcularLongitud(line);
            const necesarios = Math.max(1, Math.floor(long/1500));
            const actuales = line.components?.filter(c=>c.type==='SOPORTE').length || 0;
            if (actuales < necesarios) alertas.push(`Línea ${line.tag}: necesita ${necesarios} soportes, tiene ${actuales}`);
        }
    }
    if (alertas.length === 0) notify("Auditoría: sin observaciones");
    else { alertas.forEach(a=>notify(a,true)); notify(`${alertas.length} observaciones`,true); }
}

function exportarMTO() {
    let items = [];
    for (let eq of db.equipos) {
        if (eq.type === 'point') continue;
        let desc = eq.tipo==='tanque_v' ? `Tanque vertical diametro ${(eq.diametro/1000).toFixed(1)}m altura ${(eq.altura/1000).toFixed(1)}m` : (eq.tipo==='bomba' ? `Bomba centrifuga` : `Equipo ${eq.tipo}`);
        items.push([eq.tag, desc, "Und", 1]);
    }
    for (let line of db.lines) {
        let long = (calcularLongitud(line)/1000).toFixed(2);
        items.push([line.tag, `Tuberia ${line.material} ${line.diameter}"`, "m", parseFloat(long)]);
        if (line.components) {
            for (let comp of line.components) {
                items.push([comp.tag, `${comp.type} ${comp.skey||''}`, "Und", 1]);
            }
        }
    }
    if (items.length===0) { notify("No hay elementos", true); return; }
    const ws = XLSX.utils.aoa_to_sheet([["Tag","Descripcion","Unidad","Cantidad"], ...items]);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, "MTO");
    XLSX.writeFile(wb, `MTO_${Date.now()}.xlsx`);
    notify("MTO exportado");
}

function exportPDF() {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ orientation: 'landscape' });
    const imgData = canvas.toDataURL('image/png');
    doc.addImage(imgData, 'PNG', 10, 10, 277, 150);
    doc.setFontSize(16);
    doc.text("SmartFlow Pro - Reporte Isometrico", 10, 175);
    doc.text(`Fecha: ${new Date().toLocaleString()}`, 10, 185);
    doc.save(`isometrico_${Date.now()}.pdf`);
    notify("PDF generado");
}

// ==================== CREAR DISTRIBUIDOR AUTOMATICO ====================
function crearDistribuidor(desdeTag, hastaTag, diametroPulgadas, material, desvioDerechoMM = 500) {
    const desdeEq = db.equipos.find(e => e.tag === desdeTag);
    const hastaEq = db.equipos.find(e => e.tag === hastaTag);
    if (!desdeEq || !hastaEq) {
        notify(`No se encontraron los equipos ${desdeTag} o ${hastaTag}`, true);
        return false;
    }
    
    let tanques = db.equipos.filter(e => e.tipo === 'tanque_v' && e.x >= Math.min(desdeEq.x, hastaEq.x) && e.x <= Math.max(desdeEq.x, hastaEq.x));
    tanques.sort((a,b) => a.x - b.x);
    
    if (tanques.length === 0) {
        notify("No se encontraron tanques en el rango", true);
        return false;
    }
    
    const colectorTag = `COLECTOR-${Date.now()}`;
    const puntosColector = [];
    const zColector = tanques[0].z + desvioDerechoMM;
    
    for (let i = 0; i < tanques.length; i++) {
        const tanque = tanques[i];
        const puntoColector = { x: tanque.x, y: tanque.y - 500, z: zColector };
        puntosColector.push(puntoColector);
        
        if (i > 0) {
            const puntoAnt = puntosColector[i-1];
            const tagTuberiaColector = `${colectorTag}-TRAMO-${i}`;
            addPipe(tagTuberiaColector, diametroPulgadas, material, [puntoAnt, puntoColector]);
        }
        
        const puntoDesvio = { x: tanque.x + desvioDerechoMM, y: tanque.y - 300, z: tanque.z };
        const tagDerivacion = `DER-${tanque.tag}`;
        
        addPipe(`${tagDerivacion}-1`, diametroPulgadas, material, [
            { x: tanque.x, y: tanque.y, z: tanque.z },
            puntoDesvio
        ]);
        
        addPipe(`${tagDerivacion}-2`, diametroPulgadas, material, [
            puntoDesvio,
            puntoColector
        ]);
    }
    
    notify(`Distribuidor creado: ${tanques.length} tanques conectados con tuberia de ${diametroPulgadas}" ${material}`);
    return true;
}

// ==================== PARSER DE COMANDOS ====================
function parseCommand(cmd) {
    const lower = cmd.toLowerCase();
    
    if (lower.includes('resumen') || lower.includes('que hay') || lower.includes('listar') || lower.includes('dime los elementos')) {
        const tanques = db.equipos.filter(e => e.tipo === 'tanque_v');
        const bombas = db.equipos.filter(e => e.tipo === 'bomba');
        const tuberias = db.lines;
        let totalComponentes = 0;
        let longitudTotal = 0;
        tuberias.forEach(l => {
            longitudTotal += calcularLongitud(l) / 1000;
            totalComponentes += l.components ? l.components.length : 0;
        });
        let mensaje = `El proyecto tiene ${tanques.length} tanques. `;
        if (tanques.length > 0) mensaje += `Nombres: ${tanques.map(t => t.tag).join(", ")}. `;
        mensaje += `${bombas.length} bombas. `;
        if (bombas.length > 0) mensaje += `Nombres: ${bombas.map(b => b.tag).join(", ")}. `;
        mensaje += `${tuberias.length} tuberias, con una longitud total de ${longitudTotal.toFixed(1)} metros. `;
        if (totalComponentes > 0) mensaje += `Ademas, hay ${totalComponentes} componentes instalados. `;
        notify(mensaje);
        return true;
    }
    
    if (lower.includes('eliminar') || lower.includes('borrar')) {
        const tagMatch = cmd.match(/\b([A-Z0-9-]+)\b/);
        if (tagMatch) {
            const tag = tagMatch[1].toUpperCase();
            const antesEq = db.equipos.length;
            db.equipos = db.equipos.filter(e => e.tag !== tag);
            const antesLine = db.lines.length;
            db.lines = db.lines.filter(l => l.tag !== tag);
            if (db.equipos.length < antesEq || db.lines.length < antesLine) {
                notify(`Elemento ${tag} eliminado`);
                saveState();
                render();
                autoCenter();
            } else {
                notify(`No se encontró ${tag}`, true);
            }
        } else {
            notify("Debe especificar el tag del elemento a eliminar", true);
        }
        return true;
    }
    
    if (lower.includes('crea distribuidor') || lower.includes('crea colector')) {
        let diametro = 4;
        const diamMatch = lower.match(/(\d+)\s*pulgadas/);
        if (diamMatch) diametro = parseInt(diamMatch[1]);
        
        let desde = "TK-01", hasta = "TK-06";
        const desdeMatch = cmd.match(/desde\s+([A-Z0-9-]+)/i);
        const hastaMatch = cmd.match(/hasta\s+([A-Z0-9-]+)/i);
        if (desdeMatch) desde = desdeMatch[1].toUpperCase();
        if (hastaMatch) hasta = hastaMatch[1].toUpperCase();
        
        let desvio = 500;
        const desvioMatch = lower.match(/desvio\s+(?:derecho\s+)?(\d+)\s*mm/);
        if (desvioMatch) desvio = parseInt(desvioMatch[1]);
        
        crearDistribuidor(desde, hasta, diametro, 'PPR', desvio);
        return true;
    }
    
    if (lower.includes('crea') && (lower.includes('tanque') || lower.includes('tanques'))) {
        let cant = 1;
        const m = lower.match(/(\d+)\s+tanques?/);
        if (m) cant = parseInt(m[1]);
        
        let diam = 2400, alt = 2900;
        const dMatch = lower.match(/(?:di[áa]metro\s+de\s+)(\d+)\s*mm|de\s+(\d+)\s*mm\s+di[áa]metro|(\d+)\s*mm\s+di[áa]metro/i);
        if (dMatch) diam = parseInt(dMatch[1] || dMatch[2] || dMatch[3]);
        const aMatch = lower.match(/(?:altura\s+de\s+)(\d+)\s*mm|de\s+(\d+)\s*mm\s+altura|(\d+)\s*mm\s+altura/i);
        if (aMatch) alt = parseInt(aMatch[1] || aMatch[2] || aMatch[3]);
        
        for (let i = 0; i < cant; i++) addEquipment('tanque_v', 'TK', diam, alt);
        return true;
    }
    
    if (lower.includes('crea') && (lower.includes('bomba') || lower.includes('bombas'))) {
        let cant = 1;
        const m = lower.match(/(\d+)\s+bombas?/);
        if (m) cant = parseInt(m[1]);
        for (let i = 0; i < cant; i++) addEquipment('bomba', 'B', 800, 800);
        return true;
    }
    
    if (lower.includes('conecta')) {
        const tags = [...cmd.matchAll(/([A-Z0-9-]+)/g)].map(m=>m[1]);
        if (tags.length >= 2) {
            const e1 = db.equipos.find(e=>e.tag===tags[0]);
            const e2 = db.equipos.find(e=>e.tag===tags[1]);
            if (e1 && e2) {
                let diam = 4;
                const d = lower.match(/(\d+)\s+pulgadas/);
                if (d) diam = parseInt(d[1]);
                const points = [
                    { x: e1.x, y: e1.y + 300, z: e1.z },
                    { x: (e1.x+e2.x)/2, y: e1.y + 500, z: (e1.z+e2.z)/2 },
                    { x: e2.x, y: e2.y + 300, z: e2.z }
                ];
                addPipe(`L-${tags[0]}-${tags[1]}`, diam, 'PPR', points);
                return true;
            } else notify("Equipo no encontrado", true);
        }
        return false;
    }
    
    if (lower.includes('aplicar normas')) {
        aplicarNormas();
        return true;
    }
    
    if (lower.includes('auditar planta')) {
        auditarPlanta();
        return true;
    }
    
    if (lower.includes('exportar mto')) {
        exportarMTO();
        return true;
    }
    
    notify(`Comando no reconocido: "${cmd}"`, true);
    return false;
}

// ==================== INTERACCION CON EL CANVAS ====================
function pickElement(mouse) {
    for (let eq of db.equipos) {
        const p = project(eq);
        const w = (eq.diametro/2)*cam.scale;
        const dist = Math.hypot(mouse.x - p.x, mouse.y - p.y);
        if (dist < w+5) return { type:'equipment', obj:eq };
    }
    for (let line of db.lines) {
        if (!line.points3D) continue;
        const proj = line.points3D.map(p => project(p));
        for (let i=0; i<proj.length-1; i++) {
            const dist = pointToSegmentDistance(mouse, proj[i], proj[i+1]);
            if (dist < 10) return { type:'line', obj:line };
        }
    }
    return null;
}

function pointToSegmentDistance(p, a, b) {
    const ax = p.x-a.x, ay = p.y-a.y;
    const bx = b.x-a.x, by = b.y-a.y;
    const dot = ax*bx + ay*by;
    const len2 = bx*bx + by*by;
    if (len2===0) return Math.hypot(ax,ay);
    let t = dot/len2;
    t = Math.max(0, Math.min(1,t));
    const projX = a.x + t*bx;
    const projY = a.y + t*by;
    return Math.hypot(p.x-projX, p.y-projY);
}

function initCanvasEvents() {
    canvas.addEventListener('mousedown', (e) => {
        dragging = true;
        lastPos = { x: e.clientX, y: e.clientY };
        canvas.style.cursor = 'grabbing';
        const rect = canvas.getBoundingClientRect();
        const mouseCanvas = { x: (e.clientX - rect.left) * canvas.width / rect.width, y: (e.clientY - rect.top) * canvas.height / rect.height };
        const picked = pickElement(mouseCanvas);
        selectedElement = picked || null;
        render();
        e.preventDefault();
    });
    window.addEventListener('mousemove', (e) => {
        if (!dragging) return;
        const dx = e.clientX - lastPos.x;
        const dy = e.clientY - lastPos.y;
        cam.panX += dx;
        cam.panY += dy;
        lastPos = { x: e.clientX, y: e.clientY };
        render();
    });
    window.addEventListener('mouseup', () => { dragging = false; canvas.style.cursor = 'grab'; });
    canvas.addEventListener('wheel', (e) => {
        e.preventDefault();
        const delta = e.deltaY > 0 ? 0.9 : 1.1;
        cam.scale *= delta;
        cam.scale = Math.min(Math.max(0.1, cam.scale), 1.5);
        render();
    });
    canvas.addEventListener('touchstart', (e) => {
        e.preventDefault();
        if (e.touches.length === 1) {
            dragging = true;
            lastPos = { x: e.touches[0].clientX, y: e.touches[0].clientY };
            const rect = canvas.getBoundingClientRect();
            const touchCanvas = { x: (e.touches[0].clientX - rect.left) * canvas.width / rect.width, y: (e.touches[0].clientY - rect.top) * canvas.height / rect.height };
            const picked = pickElement(touchCanvas);
            selectedElement = picked || null;
            render();
        }
    });
    window.addEventListener('touchmove', (e) => {
        if (!dragging || e.touches.length !== 1) return;
        const dx = e.touches[0].clientX - lastPos.x;
        const dy = e.touches[0].clientY - lastPos.y;
        cam.panX += dx;
        cam.panY += dy;
        lastPos = { x: e.touches[0].clientX, y: e.touches[0].clientY };
        render();
    });
    window.addEventListener('touchend', () => { dragging = false; });
}

// ==================== PERSISTENCIA ====================
function guardarProyecto() {
    localStorage.setItem('smartflow_pro', JSON.stringify({ equipos: db.equipos, lines: db.lines }));
    notify("Proyecto guardado");
}
function cargarProyecto() {
    const data = localStorage.getItem('smartflow_pro');
    if (data) {
        const p = JSON.parse(data);
        db.equipos = p.equipos || [];
        db.lines = p.lines || [];
        selectedElement = null;
        render();
        autoCenter();
        notify("Proyecto cargado");
    } else notify("No hay proyecto guardado", true);
}
function nuevoProyecto() {
    if (confirm("Borrar todo?")) {
        db = { equipos: [], lines: [] };
        selectedElement = null;
        render();
        autoCenter();
        notify("Nuevo proyecto");
        saveState();
    }
}

function toggleVoice() {
    voiceEnabled = !voiceEnabled;
    const btn = document.getElementById('btnVoice');
    btn.textContent = voiceEnabled ? "Voz ON" : "Voz OFF";
    notify(voiceEnabled ? "Voz activada" : "Voz desactivada");
}

// ==================== INICIALIZACION ====================
function resizeCanvas() {
    const container = canvas.parentElement;
    canvas.width = container.clientWidth;
    canvas.height = container.clientHeight;
    autoCenter();
}

function init() {
    resizeCanvas();
    initCanvasEvents();
    
    db.equipos.push({ tag: 'TK-01', tipo: 'tanque_v', x: 2000, y: 1250, z: 0, diametro: 2400, altura: 2500 });
    db.lines.push({ tag: 'L-101', diameter: 4, material: 'PPR', points3D: [{x:2000, y:1500, z:0}, {x:5000, y:1500, z:0}], components: [] });
    render();
    autoCenter();
    saveState();

    document.getElementById('btnNew').onclick = nuevoProyecto;
    document.getElementById('btnOpen').onclick = cargarProyecto;
    document.getElementById('btnSave').onclick = guardarProyecto;
    document.getElementById('btnReset').onclick = autoCenter;
    document.getElementById('btnCommand').onclick = () => document.getElementById('commandPanel').style.display = 'block';
    document.getElementById('closeCommand').onclick = () => document.getElementById('commandPanel').style.display = 'none';
    document.getElementById('runCommands').onclick = () => {
        const text = document.getElementById('commandText').value;
        const lines = text.split('\n');
        for (let l of lines) if (l.trim()) parseCommand(l);
        document.getElementById('commandPanel').style.display = 'none';
        render();
        autoCenter();
    };
    document.getElementById('clearCommand').onclick = () => document.getElementById('commandText').value = '';
    document.getElementById('btnMTO').onclick = exportarMTO;
    document.getElementById('btnPDF').onclick = exportPDF;
    document.getElementById('btnUndo').onclick = undo;
    document.getElementById('btnRedo').onclick = redo;
    document.getElementById('btnVoice').onclick = toggleVoice;
    document.getElementById('btnApplyNorm').onclick = aplicarNormas;

    window.addEventListener('resize', () => { resizeCanvas(); autoCenter(); });
    notify("SmartFlow Pro v7.8 - Listo");
}

init();
</script>
</body>
</html>
